{
    "version": 2,
    "builds": [
        {
            "src": "image/*.html",
            "use": "@vercel/static"
        },
        {
            "src": "dd/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*\\.html)",
            "dest": "/image/$1"
        },
        {
            "src": "/(.*\\.(js|css))",
            "dest": "/image/$1"
        },
        {
            "src": "/(.*\\.(jpg|webp|png))",
            "dest": "/dd/$1"
        },
        {
            "src": "/",
            "dest": "/image/index.html"
        }
    ]
}